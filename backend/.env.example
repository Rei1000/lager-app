APP_NAME=lager-app-backend
APP_ENV=development

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lagerapp
POSTGRES_USER=lagerapp
POSTGRES_PASSWORD=lagerapp

DATABASE_URL=
DB_ECHO=false
AUTH_SECRET_KEY=lager-app-dev-secret
AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
ERP_PROFILE_NAME=default
PHOTO_UPLOAD_DIRECTORY=uploads
DEMO_SEED_ON_STARTUP=false
# Mehrere Origins komma-separiert, z. B. Desktop + Smartphone-LAN-URL
CORS_ALLOW_ORIGINS=http://localhost:3001,http://192.168.178.160:3001
SAGE_SIMULATOR_BASE_URL=http://localhost:8000/simulator/sage
